# === Supabase ===
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# === App ===
# The public URL of your deployed app. For local dev use http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Allowlist ===
# Comma-separated list of emails allowed to sign in
# Update these to your 2 team emails (Richard + Michael)
ALLOWLIST_EMAILS=richard@taggrading.com,michael@taggrading.com

# === Optional ===
# Phone number for the in-app "Text Michael" button in the top bar.
# E.164 format preferred ('+14155551234'); bare 10-digit also works on iOS.
# If unset/empty, the chat icon is hidden automatically.
NEXT_PUBLIC_MICHAEL_PHONE=
